{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "updater:default",
    "process:default",
    "dialog:default",
    "notification:default",
    "opener:default",
    "opener:allow-open-url"
  ]
}
